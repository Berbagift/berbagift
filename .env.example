# ==============================================================================
# BagiTHR Unified Environment Variables Template
# Copy this file to .env and fill in your secrets.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# Use 'db' when running within Docker, or '127.0.0.1' for local native execution.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_db_password
DB_NAME=bagithr
# Required to bootstrap the database container (MySQL root password)
DB_ROOT_PASSWORD=your_secure_root_password

# --- BACKEND / FASTAPI CONFIGURATION ---
# App environment: production, staging, development
APP_ENV=development
BACKEND_URL=http://localhost:8000

# --- FRONTEND / NEXT.JS CONFIGURATION ---
# API Mode: 'local' (offline JSON files) or 'server' (Axios HTTP requests to backend)
NEXT_PUBLIC_API_MODE=server

# Backend API URL.
# In local development without Nginx, use http://localhost:8000.
# In production/staging with Nginx proxy, use "/api" (relative url).
NEXT_PUBLIC_API_URL=/api

# Stellar network environment: TESTNET or PUBLIC
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Toggle auth middleware route protection (true/false)
NEXT_PUBLIC_ENABLE_AUTH_MIDDLEWARE=false

# --- PINATA (FRONTEND) ---
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_PINATA_SECRET_API_KEY=

# --- CONTRACTS ---
SWAP_CONTRACT_ID=
NFT_GIFT_CONTRACT_ID=
MARKETPLACE_CONTRACT_ID=

# --- FRONTEND CONTRACTS ---
NEXT_PUBLIC_SWAP_CONTRACT_ID=
NEXT_PUBLIC_NFT_GIFT_CONTRACT_ID=
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ID=
NEXT_PUBLIC_XLM_SAC_ADDRESS=
NEXT_PUBLIC_RPK_CONTRACT=

# --- MONGODB CONFIGURATION ---
MONGO_PORT=27017
MONGO_USER=root
MONGO_PASSWORD=your_secure_mongo_password
MONGO_DB_NAME=bagithr_indexer
MONGO_URI=mongodb://root:your_secure_mongo_password@127.0.0.1:27017/bagithr_indexer?authSource=admin
