# ═══════════════════════════════════════════════════════════════
# BagiTHR — Frontend .env.example
# Semua ter-mount sebagai NEXT_PUBLIC_ build-time arg.
# ═══════════════════════════════════════════════════════════════

# ── API ───────────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_MODE=server
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=

# ── Stellar ───────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# ── Auth ──────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AUTH_MIDDLEWARE=true

# ── Pinata (IPFS) ─────────────────────────────────────────────
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_PINATA_SECRET_API_KEY=

# ── Contracts ─────────────────────────────────────────────────
NEXT_PUBLIC_SWAP_CONTRACT_ID=
NEXT_PUBLIC_NFT_GIFT_CONTRACT_ID=
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ID=
NEXT_PUBLIC_MULTI_ROOM_CONTRACT_ID=
NEXT_PUBLIC_XLM_SAC_ADDRESS=
NEXT_PUBLIC_RPK_CONTRACT=
